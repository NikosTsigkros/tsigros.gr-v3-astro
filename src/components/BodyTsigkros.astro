        class="section works align-left"
        id="works-section"
    >
        <div class="fw">
        <div class="titles">
            <h2 class="title">My Work</h2>
        </div>
        <div class="filters">
            <div class="f_btn active">
            <label
                ><input
                type="radio"
                name="fl_radio"
                value="box-item"
                />All</label
            >
            </div>
            <div class="f_btn">
            <label
                ><input
                type="radio"
                name="fl_radio"
                value="f-nextjs"
                />Nextjs</label
            >
            </div>
            <div class="f_btn">
            <label
                ><input
                type="radio"
                name="fl_radio"
                value="f-react"
                />React</label
            >
            </div>
            <div class="f_btn">
            <label
                ><input
                type="radio"
                name="fl_radio"
                value="f-nodejs"
                />Nodejs</label
            >
            </div>
            <div class="f_btn">
            <label
                ><input
                type="radio"
                name="fl_radio"
                value="f-wordpress"
                />Wordpress</label
