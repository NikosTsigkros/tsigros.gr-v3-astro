            </div>
            </div>
            <div
            class="col col-m-12 col-t-6 col-d-4 box-item f-wordpress"
            >
            <div class="item">
                <div class="desc">
                <div class="image">
                    <a href="#popup-4" class="has-popup"
                    ><img src="images/works/small/moka-small.jpg" alt="Moka Patisserie - Bakery Website"
                    /></a>
                </div>
                </div>
            </div>
            <div id="popup-4" class="popup-box mfp-fade mfp-hide">
                <div class="content">
                <div class="image">
                    <img src="images/works/moka.png" alt="Moka Patisserie - Full Website Preview" />
                </div>
                <div class="desc">
                    <div class="category">Website</div>
                    <h3>Moka Patisserie</h3>
                    <p>
                    Responsible for creating the digital presence for Rolima, a leading industrial wear protection supplier and installer in Cyprus. The modern UI and headless architecture ensure seamless content management and excellent user experience.
                    </p>
