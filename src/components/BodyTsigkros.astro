        ></a>
        <a target="blank" href="https://codepen.io/TsigkrosNikos"
            ><i class="icon ion ion-social-codepen"></i
        ></a>
        <a
            target="blank"
            href="https://www.instagram.com/NikosNikos_the_greek/"
            ><i class="icon ion ion-social-instagram"></i
        ></a>
        </div>
        <div class="copy">© {currentYear} tsigros.gr. All rights reserved.</div>
    </footer>
    </div>
