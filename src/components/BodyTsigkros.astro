                </div>
                </div>
            </div>
            </div>
            <div
            class="col col-m-12 col-t-6 col-d-4 box-item f-nextjs f-wordpress f-react"
            >
            <div class="item">
                <div class="desc">
                <div class="image">
                    <a href="#popup-2" class="has-popup"
                    ><img src="images/works/small/rolima2.jpg" alt="Rolima Ltd - Industrial Wear Protection Website"
                    /></a>
                </div>
                </div>
            </div>
            <div id="popup-2" class="popup-box mfp-fade mfp-hide">
